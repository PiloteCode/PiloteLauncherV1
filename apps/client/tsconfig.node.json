{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023"],
    "types": ["node", "electron-vite/node"],
    "outDir": "out",
    "baseUrl": ".",
    "paths": {
      "@main/*": ["electron/main/*"],
      "@shared/*": ["electron/shared/*"]
    }
  },
  "include": [
    "electron/**/*.ts",
    "electron.vite.config.ts"
  ]
}
