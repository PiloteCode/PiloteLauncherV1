{
  "name": "@pilote/client",
  "version": "1.0.0",
  "private": true,
  "description": "Pilote Project — Minecraft Java custom launcher (Electron + Vue 3).",
  "main": "./out/main/index.js",
  "author": "PiloteCode",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck:node": "tsc -p tsconfig.node.json --noEmit",
    "typecheck:web": "vue-tsc -p tsconfig.web.json --noEmit",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "lint": "eslint . --ext .ts,.vue",
    "start": "electron-vite preview",
    "pack": "electron-vite build && electron-builder --dir",
    "dist": "electron-vite build && electron-builder",
    "dist:win": "electron-vite build && electron-builder --win --publish never",
    "publish": "electron-vite build && electron-builder --publish always",
    "clean": "rimraf out dist release"
  },
  "dependencies": {
    "@pilote/core": "workspace:*",
    "@pilote/types": "workspace:*",
    "@xmcl/core": "^2.15.1",
    "@xmcl/installer": "^6.1.2",
    "@xmcl/mod-parser": "^3.4.2",
    "undici": "^7.2.0",
    "electron-updater": "^6.3.9",
    "electron-log": "^5.2.4",
    "conf": "^13.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "@vueuse/core": "^12.3.0",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "eslint": "^9.17.0",
    "lucide-vue-next": "^0.469.0",
    "motion-v": "^2.3.0",
    "pinia": "^2.3.0",
    "postcss": "^8.4.49",
    "reka-ui": "^2.0.0",
    "rimraf": "^6.0.1",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vite-plugin-javascript-obfuscator": "^3.1.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "vue-sonner": "^2.0.9",
    "vue-tsc": "^2.2.0"
  }
}
