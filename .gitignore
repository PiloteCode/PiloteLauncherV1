# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
out/
build/
.next/
.turbo/
*.tsbuildinfo
release/
dist-electron/

# The launcher's electron-builder resources (app icons) are source files, not output —
# keep them even though `build/` is ignored above.
!apps/client/build/
!apps/client/build/**

# Environment — NEVER commit real secrets
.env
.env.local
.env.*.local
.env.production
.env.development
!.env.example

# Database
*.db
*.db-journal
*.sqlite
*.sqlite3
prisma/dev.db*
web/prisma/*.db*

# Logs
*.log
logs/
npm-debug.log*
pnpm-debug.log*

# Storage (content-addressed uploaded files)
web/storage/
storage/

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
*.swp

# Auth / secrets
*.pem
*.key
auth-secret.txt

# Test / coverage
coverage/
.nyc_output/

# Misc
*.local
tmp/
.cache/
