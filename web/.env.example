# ──────────────────────────────────────────────────────────────────────────────
# Pilote Project — web (.env). Copy to .env and fill in. NEVER commit the real .env.
# ──────────────────────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=production
PORT=3000

# Public base URL of this deployment (used for absolute file/download URLs & update feed).
NEXT_PUBLIC_APP_URL=https://cdn.pilote.example
APP_URL=https://cdn.pilote.example

# Database.
#  - Dev (default schema): SQLite, zero setup ->  file:./prisma/dev.db
#  - Prod: switch prisma/schema.prisma datasource provider to "postgresql" and use:
#          postgresql://USER:PASSWORD@HOST:5432/pilote?schema=public
DATABASE_URL="file:./prisma/dev.db"

# Better Auth (admin sessions). Generate: `openssl rand -base64 48`
BETTER_AUTH_SECRET="CHANGE_ME_generate_with_openssl_rand_base64_48"
BETTER_AUTH_URL=https://cdn.pilote.example

# First admin, created idempotently by the seed script.
ADMIN_EMAIL=admin@pilote.example
ADMIN_PASSWORD=CHANGE_ME_strong_password
ADMIN_NAME=Administrateur

# JWT used to sign short-lived, instance-scoped unlock tokens. Generate: `openssl rand -base64 48`
INSTANCE_JWT_SECRET="CHANGE_ME_generate_with_openssl_rand_base64_48"
# Token TTL in seconds (default 1h).
INSTANCE_TOKEN_TTL=3600

# File storage. "local" = content-addressed on disk under STORAGE_DIR. "s3" = MinIO/S3.
STORAGE_DRIVER=local
STORAGE_DIR=./storage

# Optional S3 / MinIO (only when STORAGE_DRIVER=s3)
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=pilote-files
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Rate limiting for unlock attempts (per IP).
UNLOCK_MAX_ATTEMPTS=10
UNLOCK_WINDOW_SECONDS=600
