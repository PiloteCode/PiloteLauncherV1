# ──────────────────────────────────────────────────────────────────────────────
# Pilote Project — monorepo root .env.example.
# Per-app envs live in web/.env (see web/.env.example). This root file holds shared
# defaults consumed during local development. NEVER commit the real .env files.
# ──────────────────────────────────────────────────────────────────────────────

# Default backend the Electron client talks to in dev.
PILOTE_API_BASE_URL=http://localhost:3000

# GitHub repo used by electron-builder for auto-update publishing.
GH_OWNER=PiloteCode
GH_REPO=PiloteLauncherV1

# electron-builder publish token (used only in CI). Generate a GitHub PAT with `repo` scope.
GH_TOKEN=
